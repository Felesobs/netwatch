# PostgreSQL connection string. For local development with Docker Compose,
# this matches docker-compose.yml. For production, use your Supabase /
# managed Postgres connection string (prefer the pooled connection on port
# 6543 for serverless deployments, with a separate DIRECT_URL for migrations).
DATABASE_URL="postgresql://netwatch:netwatch@localhost:5432/netwatch?schema=public"

# Used by Prisma Migrate to connect directly (bypassing connection poolers
# like PgBouncer/Supavisor, which don't support the advisory locks Migrate
# needs). Only required when DATABASE_URL points at a pooled connection.
# DIRECT_URL="postgresql://netwatch:netwatch@localhost:5432/netwatch?schema=public"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-plus-character-secret"

# Base URL of the deployed app, used for absolute links (e.g. in emails, if
# added later). Defaults to localhost in development.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
